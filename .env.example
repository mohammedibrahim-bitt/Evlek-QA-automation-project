# Required: Evlek live or staging URL.
BASE_URL=https://evlek.app/

# Optional: use only provided fake/test accounts.
TEST_USER_EMAIL=qa.user@example.com
TEST_USER_PASSWORD=replace-with-provided-test-password

# Optional: override if the login page is not discoverable from the homepage.
LOGIN_URL=/login

# Optional: journey test data. Keep values fake and non-sensitive.
TEST_SEARCH_TERM=test
TEST_FULL_NAME=QA Test User
TEST_PHONE=+10000000000

# Optional: breadth limit for the internal-link audit.
AUDIT_MAX_PAGES=30
AUDIT_PAGE_DELAY_MS=500
AUDIT_MAX_LINKS=100

# Optional: performance smoke thresholds in milliseconds.
PERF_MAX_DOM_CONTENT_LOADED_MS=8000
PERF_MAX_LOAD_EVENT_MS=15000
PERF_MAX_FIRST_VISIBLE_MS=5000
PERF_MAX_FAILED_REQUESTS=5
